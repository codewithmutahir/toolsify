# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Ads
NEXT_PUBLIC_ADS_ENABLED=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Email
RESEND_API_KEY=
CONTACT_EMAIL=
RESEND_FROM_EMAIL=Toolsify <onboarding@resend.dev>

# DNS-AID (Cloudflare — only needed to run npm run dns-aid:publish)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
# DNS_AID_ZONE_NAME=toolsify.online
# DNS_AID_TARGET=www.toolsify.online

# Google reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Optional minimum score threshold (0.0–1.0, default 0.5)
RECAPTCHA_MIN_SCORE=0.5

# Rate limiting (Upstash Redis — add via Vercel Marketplace or https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
